# Maintainer: londospark <londospark@users.noreply.github.com>
pkgname=broadcast-git
pkgver=r1.PLACEHOLDER
pkgrel=1
pkgdesc="AI-powered per-application noise suppression for PipeWire"
arch=('x86_64')
url="https://github.com/londospark/broadcast"
license=('GPL-3.0-or-later')
depends=('pipewire' 'pipewire-pulse' 'gtk4' 'libadwaita' 'deepfilternet')
makedepends=('rust' 'cargo' 'git' 'pkg-config')
provides=('broadcast')
conflicts=('broadcast' 'broadcast-bin')
source=("${pkgname}::git+${url}.git")
sha256sums=('SKIP')

pkgver() {
    cd "${pkgname}"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd "${pkgname}"
    cargo build --release --locked
}

check() {
    cd "${pkgname}"
    cargo test --release --locked
}

package() {
    cd "${pkgname}"
    install -Dm755 "target/release/broadcast-ctl" "${pkgdir}/usr/bin/broadcast-ctl"
    install -Dm755 "target/release/broadcast-gui" "${pkgdir}/usr/bin/broadcast-gui"
    install -Dm644 "broadcast-gui.desktop" "${pkgdir}/usr/share/applications/broadcast-gui.desktop"
    install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
